NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google AI Studio API key, used by /api/diagnostics/report to generate the
# AI diagnostic report (gemini-2.5-flash). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Services checked by /api/ping-all, numbered from 1 with no gaps.
# HOST accepts an IP or FQDN. Omit all to fall back to public DNS resolver
# defaults. NOTE is optional free text (e.g. "Requires VPN") surfaced to the
# AI diagnostic report so it can explain host-specific failures instead of
# guessing at generic causes.
PING_1_NAME="Google Public DNS"
PING_1_HOST="dns.google"
PING_1_PORT=53
PING_1_NOTE=""
